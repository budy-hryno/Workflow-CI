name: loan_default_prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: { type: int, default: 136 }
      max_depth: { type: int, default: 23 }
      dataset: { type: string, default: "loan_default_preprocessing.csv" }
    command: "python modelling.py {n_estimators} {max_depth} {dataset}"
